generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditLogOutcome {
  SUCCESS
  FAILURE
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  role          UserRole @default(EDITOR)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Author {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  bioRich   Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]

  @@index([isActive])
  @@map("authors")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

model Issue {
  id          String    @id @default(uuid())
  title       String
  titleStyled Json?
  slug        String    @unique
  description Json?
  homeBlocks  Json?
  homeVariant String    @default("black")
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles Article[]

  @@index([isActive, sortOrder])
  @@index([publishedAt])
  @@map("issues")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@index([isActive])
  @@map("categories")
}

model Tag {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles ArticleTag[]

  @@index([isActive])
  @@map("tags")
}

model Article {
  id          String        @id @default(uuid())
  issueId     String
  categoryId  String
  authorId    String?
  status      ArticleStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  publishedAt DateTime?

  title       String
  titleStyled Json?
  slug        String
  excerpt     String?
  excerptRich Json?
  contentRich Json

  imageUrl    String?
  imageAlt    String?
  audioUrl    String?
  audioChunks Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue    Issue        @relation(fields: [issueId], references: [id], onDelete: Restrict)
  category Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author   Author?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  tags     ArticleTag[]

  @@unique([issueId, slug])
  @@unique([slug])
  @@index([slug])
  @@index([issueId, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([status, publishedAt])
  @@index([status, isFeatured])
  @@map("articles")
}

model ArticleTag {
  articleId String
  tagId     String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
  @@map("article_tags")
}

model Page {
  id          String     @id @default(uuid())
  title       String
  titleStyled Json?
  slug        String     @unique
  status      PageStatus @default(DRAFT)
  excerpt     String?
  excerptRich Json?
  contentRich Json
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@map("pages")
}

model NavigationMenu {
  id        String   @id @default(uuid())
  key       String   @unique
  label     String
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("navigation_menus")
}

model AuditLog {
  id           String          @id @default(uuid())
  actorId      String?
  actorEmail   String?
  actorRole    UserRole?
  action       String
  resource     String
  resourceId   String?
  outcome      AuditLogOutcome
  errorCode    String?
  errorMessage String?
  method       String
  path         String
  ipAddress    String?
  userAgent    String?
  requestId    String?
  metadata     Json?
  createdAt    DateTime        @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([resource, resourceId, createdAt])
  @@index([outcome, createdAt])
  @@map("audit_logs")
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  event       String
  path        String
  referrer    String?
  country     String?
  visitorHash String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([event, createdAt])
  @@index([path, createdAt])
  @@index([visitorHash, createdAt])
  @@map("analytics_events")
}

model WebVital {
  id             String   @id @default(uuid())
  metricId       String
  name           String
  value          Float
  delta          Float
  rating         String?
  navigationType String?
  path           String
  visitorHash    String?
  createdAt      DateTime @default(now())

  @@unique([metricId, name])
  @@index([createdAt])
  @@index([name, createdAt])
  @@index([path, createdAt])
  @@index([path, name, createdAt])
  @@map("web_vitals")
}

model ErrorLog {
  id          String   @id @default(uuid())
  fingerprint String   @unique
  source      String
  name        String?
  message     String
  digest      String?
  path        String?
  method      String?
  routePath   String?
  routeType   String?
  requestId   String?
  userAgent   String?
  count       Int      @default(1)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt
  metadata    Json?

  @@index([lastSeenAt])
  @@index([path, lastSeenAt])
  @@index([source, lastSeenAt])
  @@map("error_logs")
}

model TelemetryDailyAggregate {
  id        String   @id @default(uuid())
  date      DateTime
  event     String
  path      String
  referrer  String   @default("")
  country   String   @default("")
  views     Int      @default(0)
  visitors  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([date, event, path, referrer, country])
  @@index([date])
  @@index([event, date])
  @@index([path, date])
  @@map("telemetry_daily_aggregates")
}

model WebVitalDailyAggregate {
  id               String   @id @default(uuid())
  date             DateTime
  path             String
  name             String
  count            Int      @default(0)
  p50              Float?
  p75              Float?
  p95              Float?
  good             Int      @default(0)
  needsImprovement Int      @default(0)
  poor             Int      @default(0)
  updatedAt        DateTime @updatedAt

  @@unique([date, path, name])
  @@index([date])
  @@index([name, date])
  @@index([path, date])
  @@map("web_vital_daily_aggregates")
}
