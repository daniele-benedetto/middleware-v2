generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditLogOutcome {
  SUCCESS
  FAILURE
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  role          UserRole @default(EDITOR)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Author {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  bioRich   Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]

  @@index([isActive])
  @@map("authors")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

model Issue {
  id          String    @id @default(uuid())
  title       String
  titleStyled Json?
  slug        String    @unique
  description Json?
  homeBlocks  Json?
  homeVariant String    @default("black")
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles Article[]

  @@index([isActive, sortOrder])
  @@index([publishedAt])
  @@map("issues")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@index([isActive])
  @@map("categories")
}

model Article {
  id          String        @id @default(uuid())
  issueId     String
  categoryId  String
  authorId    String?
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?

  title       String
  titleStyled Json?
  slug        String
  excerpt     String?
  excerptRich Json?
  contentRich Json

  imageUrl    String?
  imageAlt    String?
  audioUrl    String?
  audioChunks Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue    Issue    @relation(fields: [issueId], references: [id], onDelete: Restrict)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author   Author?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([issueId, slug])
  @@unique([slug])
  @@index([slug])
  @@index([issueId, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([status, publishedAt])
  @@map("articles")
}

model Course {
  id          String    @id @default(uuid())
  title       String
  titleStyled Json?
  slug        String    @unique
  description Json?
  homeVariant String    @default("black")
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lessons Lesson[]

  @@index([isActive, sortOrder])
  @@index([publishedAt])
  @@map("courses")
}

model Lesson {
  id          String       @id @default(uuid())
  courseId    String
  status      LessonStatus @default(DRAFT)
  sortOrder   Int          @default(0)
  publishedAt DateTime?

  title       String
  titleStyled Json?
  slug        String
  excerpt     String?
  excerptRich Json?
  contentRich Json

  imageUrl    String?
  imageAlt    String?
  audioUrl    String?
  audioChunks Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@unique([courseId, slug])
  @@index([courseId, sortOrder])
  @@index([status, publishedAt])
  @@map("lessons")
}

model Page {
  id          String     @id @default(uuid())
  title       String
  titleStyled Json?
  slug        String     @unique
  status      PageStatus @default(DRAFT)
  excerpt     String?
  excerptRich Json?
  contentRich Json
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@map("pages")
}

model NavigationMenu {
  id        String   @id @default(uuid())
  key       String   @unique
  label     String
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("navigation_menus")
}

model AuditLog {
  id           String          @id @default(uuid())
  actorId      String?
  actorEmail   String?
  actorRole    UserRole?
  action       String
  resource     String
  resourceId   String?
  outcome      AuditLogOutcome
  errorCode    String?
  errorMessage String?
  method       String
  path         String
  ipAddress    String?
  userAgent    String?
  requestId    String?
  metadata     Json?
  createdAt    DateTime        @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([resource, resourceId, createdAt])
  @@index([outcome, createdAt])
  @@map("audit_logs")
}
