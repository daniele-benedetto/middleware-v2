generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditOutcome {
  SUCCESS
  FAILURE
}

enum AuditRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditChangeType {
  CREATED
  UPDATED
  REMOVED
  REORDERED
}

enum ObservabilityEventCategory {
  SESSION
  NAVIGATION
  INTERACTION
  ERROR
  PERFORMANCE
}

enum ObservabilityErrorSource {
  SERVER
  CLIENT
  BOUNDARY
}

enum ObservabilityErrorSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ObservabilityErrorStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  IGNORED
}

enum ObservabilityImpactArea {
  CMS
  PUBLIC_SITE
  AUTH
  MEDIA
  EDITORIAL
  UNKNOWN
}

enum ObservabilityUserImpact {
  NONE
  MINOR
  BLOCKED_ACTION
  LOST_CONTENT
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  role          UserRole @default(EDITOR)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Author {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  bioRich   Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]

  @@index([isActive])
  @@map("authors")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

model Issue {
  id          String    @id @default(uuid())
  title       String
  titleStyled Json?
  slug        String    @unique
  description Json?
  homeBlocks  Json?
  homeVariant String    @default("black")
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles Article[]

  @@index([isActive, sortOrder])
  @@index([publishedAt])
  @@map("issues")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@index([isActive])
  @@map("categories")
}

model Tag {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles ArticleTag[]

  @@index([isActive])
  @@map("tags")
}

model Article {
  id          String        @id @default(uuid())
  issueId     String
  categoryId  String
  authorId    String?
  status      ArticleStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  publishedAt DateTime?

  title       String
  titleStyled Json?
  slug        String
  excerpt     String?
  excerptRich Json?
  contentRich Json

  imageUrl    String?
  imageAlt    String?
  audioUrl    String?
  audioChunks Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue    Issue        @relation(fields: [issueId], references: [id], onDelete: Restrict)
  category Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author   Author?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  tags     ArticleTag[]

  @@unique([issueId, slug])
  @@unique([slug])
  @@index([slug])
  @@index([issueId, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([status, publishedAt])
  @@index([status, isFeatured])
  @@map("articles")
}

model ArticleTag {
  articleId String
  tagId     String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
  @@map("article_tags")
}

model Page {
  id          String     @id @default(uuid())
  title       String
  titleStyled Json?
  slug        String     @unique
  status      PageStatus @default(DRAFT)
  excerpt     String?
  excerptRich Json?
  contentRich Json
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@map("pages")
}

model NavigationMenu {
  id        String   @id @default(uuid())
  key       String   @unique
  label     String
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("navigation_menus")
}

model AuditActivity {
  id               String         @id @default(uuid())
  actorId          String?
  actorSnapshot    Json?
  action           String
  resourceType     String
  resourceId       String?
  resourceSnapshot Json?
  outcome          AuditOutcome
  riskLevel        AuditRiskLevel
  riskReasons      Json?
  changedFields    String[]       @default([])
  beforeSummary    Json?
  afterSummary     Json?
  attemptedSummary Json?
  publicImpact     Boolean        @default(false)
  requestId        String?
  correlationId    String?
  reason           String?
  errorCode        String?
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime       @default(now())

  changes AuditChange[]

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@index([outcome, createdAt])
  @@index([riskLevel, createdAt])
  @@index([publicImpact, createdAt])
  @@index([requestId])
  @@index([correlationId])
  @@map("audit_activities")
}

model AuditChange {
  id                  String          @id @default(uuid())
  auditActivityId     String
  field               String
  beforeValueRedacted Json?
  afterValueRedacted  Json?
  changeType          AuditChangeType
  createdAt           DateTime        @default(now())

  activity AuditActivity @relation(fields: [auditActivityId], references: [id], onDelete: Cascade)

  @@index([auditActivityId])
  @@index([field])
  @@map("audit_changes")
}

model ObservabilitySession {
  id             String    @id
  visitorHash    String
  startedAt      DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  endedAt        DateTime?
  landingPath    String?
  exitPath       String?
  referrerDomain String?
  country        String?
  userAgent      String?
  isLikelyBot    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  events                 ObservabilityEvent[]
  errorOccurrences       ErrorOccurrence[]
  contentEngagements     ContentEngagement[]
  audioEngagements       AudioEngagement[]
  performanceExperiences PerformanceExperience[]

  @@index([visitorHash, startedAt])
  @@index([startedAt])
  @@index([lastSeenAt])
  @@map("observability_sessions")
}

model ObservabilityEvent {
  id               String                     @id @default(uuid())
  sessionId        String?
  visitorHash      String?
  type             String
  category         ObservabilityEventCategory
  path             String?
  pageType         String?
  contentId        String?
  contentType      String?
  requestId        String?
  correlationId    String?
  release          String?
  sampleRate       Float                      @default(1)
  clientSequence   Int?
  clientElapsedMs  Int?
  metadata         Json?
  receivedAtServer DateTime                   @default(now())

  session                ObservabilitySession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  errorOccurrences       ErrorOccurrence[]
  performanceExperiences PerformanceExperience[]

  @@index([receivedAtServer])
  @@index([sessionId, receivedAtServer])
  @@index([requestId])
  @@index([category, receivedAtServer])
  @@map("observability_events")
}

model ErrorGroup {
  id                 String                     @id @default(uuid())
  fingerprint        String                     @unique
  fingerprintVersion Int
  errorSignature     String
  title              String
  source             ObservabilityErrorSource
  severity           ObservabilityErrorSeverity
  status             ObservabilityErrorStatus   @default(OPEN)
  firstSeenAt        DateTime                   @default(now())
  lastSeenAt         DateTime                   @default(now())
  occurrenceCount    Int                        @default(1)
  affectedSessions   Int                        @default(0)
  affectedPaths      Json                       @default("[]")
  impactArea         ObservabilityImpactArea    @default(UNKNOWN)
  userImpact         ObservabilityUserImpact    @default(NONE)
  regression         Boolean                    @default(false)
  priorityScore      Int                        @default(0)
  priorityReasons    Json                       @default("[]")
  firstRelease       String?
  lastRelease        String?
  resolvedAt         DateTime?
  resolvedBy         String?
  reopenedAt         DateTime?
  reopenedBy         String?
  lastStatusAt       DateTime                   @default(now())
  lastStatusBy       String?

  occurrences ErrorOccurrence[]

  @@index([errorSignature])
  @@index([status, severity, lastSeenAt])
  @@index([source, lastSeenAt])
  @@index([impactArea, lastSeenAt])
  @@index([priorityScore, lastSeenAt])
  @@index([regression, lastSeenAt])
  @@index([lastRelease, lastSeenAt])
  @@map("error_groups")
}

model ErrorOccurrence {
  id                   String   @id @default(uuid())
  errorGroupId         String
  observabilityEventId String?
  sessionId            String?
  requestId            String?
  correlationId        String?
  path                 String?
  routePath            String?
  routeType            String?
  method               String?
  statusCode           Int?
  actionContext        String?
  userAgent            String?
  deviceType           String?
  browser              String?
  os                   String?
  stackTraceRedacted   String?
  metadata             Json?
  occurredAt           DateTime @default(now())

  errorGroup         ErrorGroup            @relation(fields: [errorGroupId], references: [id], onDelete: Cascade)
  observabilityEvent ObservabilityEvent?   @relation(fields: [observabilityEventId], references: [id], onDelete: SetNull)
  session            ObservabilitySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([errorGroupId, occurredAt])
  @@index([sessionId, occurredAt])
  @@index([requestId])
  @@index([occurredAt])
  @@map("error_occurrences")
}

model ContentEngagement {
  id                   String   @id @default(uuid())
  sessionId            String?
  visitorHash          String?
  contentType          String?
  contentId            String?
  slug                 String?
  path                 String
  pageType             String
  firstSeenAt          DateTime
  lastSeenAt           DateTime
  activeTimeMs         Int      @default(0)
  maxScrollDepth       Int      @default(0)
  scrollMilestones     Json     @default("[]")
  interactionCount     Int      @default(0)
  returnCountInSession Int      @default(0)
  refreshCount         Int      @default(0)
  completed            Boolean  @default(false)
  engagementLevel      String   @default("glance")
  exitType             String   @default("unknown")
  sampleRate           Float    @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  session ObservabilitySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([sessionId, path, contentId])
  @@index([sessionId, path])
  @@index([sessionId, contentId])
  @@index([contentType, contentId, firstSeenAt])
  @@index([pageType, firstSeenAt])
  @@index([engagementLevel, firstSeenAt])
  @@index([completed, firstSeenAt])
  @@map("content_engagements")
}

model AudioEngagement {
  id             String   @id @default(uuid())
  sessionId      String?
  visitorHash    String?
  articleId      String?
  path           String
  started        Boolean  @default(false)
  completed      Boolean  @default(false)
  listenedMs     Int      @default(0)
  completionRate Float    @default(0)
  seekCount      Int      @default(0)
  replayCount    Int      @default(0)
  firstSeenAt    DateTime
  lastSeenAt     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session ObservabilitySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([sessionId, articleId, path])
  @@index([sessionId, articleId])
  @@index([articleId, firstSeenAt])
  @@index([completed, firstSeenAt])
  @@map("audio_engagements")
}

model PerformanceExperience {
  id                      String   @id @default(uuid())
  sessionId               String?
  visitorHash             String?
  observabilityEventId    String?
  pageInstanceId          String?
  path                    String
  routePath               String?
  pageType                String
  contentId               String?
  deviceType              String?
  browser                 String?
  os                      String?
  connectionType          String?
  effectiveConnectionType String?
  saveData                Boolean?
  viewportWidth           Int?
  viewportHeight          Int?
  lcp                     Float?
  inp                     Float?
  cls                     Float?
  fcp                     Float?
  ttfb                    Float?
  rating                  String
  perceivedQuality        String
  causedEarlyExit         Boolean  @default(false)
  activeTimeMs            Int?
  exitType                String?
  hasBlockingError        Boolean  @default(false)
  correlatedErrorCount    Int      @default(0)
  qualityReasons          Json     @default("[]")
  release                 String?
  thresholdVersion        String
  sampleRate              Float    @default(1)
  occurredAt              DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  session            ObservabilitySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  observabilityEvent ObservabilityEvent?   @relation(fields: [observabilityEventId], references: [id], onDelete: SetNull)

  @@index([sessionId, occurredAt])
  @@index([sessionId, pageInstanceId, path])
  @@index([pageInstanceId, occurredAt])
  @@index([path, occurredAt])
  @@index([pageType, occurredAt])
  @@index([contentId, occurredAt])
  @@index([deviceType, occurredAt])
  @@index([rating, occurredAt])
  @@index([perceivedQuality, occurredAt])
  @@index([release, occurredAt])
  @@map("performance_experiences")
}
