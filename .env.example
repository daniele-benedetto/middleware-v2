NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Baseline esplicita per provider managed Postgres con verifica hostname/certificato.
# Se serve compatibilita libpq esplicita, usare `uselibpqcompat=true&sslmode=require`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=verify-full"
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=verify-full"
PRISMA_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=verify-full"

BETTER_AUTH_SECRET="replace-me"
BETTER_AUTH_URL="http://localhost:3000"
